{
  "name": "__MSG_appName__",
  "short_name": "__MSG_appShortName__",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "version": "1.1.9",
  "manifest_version": 3,

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "permissions": ["storage"],

  "content_scripts": [
    {
      "matches": ["https://www.tving.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png"
    }
  }
}
